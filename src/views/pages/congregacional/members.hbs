
<div id="tbar">
    <button class="btn btn-success shadow-sm" onclick="location.href='/congregacional/addmember'"><i
                    class="fas fa-plus fa-fw me-2"></i>Agregar Miembro</button>
</div>

<table data-toggle="table" data-search="true" data-filter-control="true" data-show-export="true"
    data-click-to-select="true" data-toolbar="#tbar" data-page-list="[50, 100, 200, All]"  width="100%" id="table"
    class="table table-striped table-bordered table-responsive mt-3 shadow-sm">
    <thead class="table-primary">
        <tr>
            <th data-field="nombres" data-sortable="true">Nombres</th>
            <th data-field="apellidos" data-sortable="true">Apellidos</th>
            <th data-field="email" data-sortable="true">Email</th>
            <th data-field="congregacion" data-sortable="true">Congregación</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {{#each user}}
        <tr>
            <td>{{names}}</td>
            <td>{{lastnames}}</td>
            <td>{{email}}</td>
            <td>{{congregation}}</td>
            <td>
                <div class="btn-group w-100">
                <button class="btn btn-sm btn-info" onclick="viewer('{{_id}}');"><i class="fas fa-eye fa-fw"></i></button>
                <button class="btn btn-sm btn-danger" onclick="openModal('{{_id}}');"><i class="fas fa-trash fa-fw"></i></button>
                </div>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<script>

    function viewer(id){
        $("#memr").load('/congregacional/viewmember/' + id).fadeIn('500');
    }
    const openModal = (id) => {
        bodyDelUser()
        $("#mainModal").modal("show")
    }

    const bodyDelUser = (id) => {
        $("#modalTitle").html("Eliminar Registro")
        $("#modalBody").html(`Esta Seguro de Eliminar este Registro?<br><br><div class="btn-group"><button class="btn btn-danger">Sí</button><button class="btn btn-info" onclick="cancelModal();">No</button></div>`)
    }

    const deluser = (id) => {
        console.log(id)
    }

    const cancelModal = () => {
        $("#mainModal").modal("hide")
    }
</script>


{{>end}}