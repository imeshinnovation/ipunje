{{>navbar}}

<div class="container">

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicio</a></li>
            <li class="breadcrumb-item active" aria-current="page">Sucursales</li>
        </ol>
    </nav>

    <div class="card border-0 bg-white mt-4">
        <div class="card-body p-0">

            <div id="tbar">
                <button class="btn btn-success shadow-sm" onclick="location.href='/congregacional/addsucursal'"><i
                    class="fas fa-plus fa-fw me-2"></i>Nueva Sucursal</button>
            </div>

            <table data-toggle="table" data-search="true" data-filter-control="true" data-show-export="true"
                data-click-to-select="true" data-toolbar="#tbar" data-page-list="[50, 100, 200, All]"
                data-pagination="true" width="100%" id="table"
                class="table table-striped table-bordered table-responsive mt-3 shadow-sm">
                <thead class="table-info">
                    <tr>
                        <th data-field="nombre" data-sortable="true">Nombre Sucursal</th>
                        <th data-field="tipo" data-sortable="true">Tipo</th>
                        <th data-field="direccion" data-sortable="true">Dirección</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each sucursales}}
                    <tr>
                        <td class="text-capitalize">{{nombre_sucursal}}</td>
                        <td class="text-capitalize">{{tipo_sucursal}}</td>
                        <td class="text-capitalize">{{direccion}}</td>
                        <td>
                            <div class="btn-group w-100">
                                <button class="btn btn-sm btn-info" onclick="location.href='/congregacional/viewsucursal/{{_id}}'"><i class="fas fa-eye fa-fw"></i></button>
                                <button class="btn btn-sm btn-danger"><i class="fas fa-trash fa-fw"></i></button>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            
        </div>
    </div>
</div>