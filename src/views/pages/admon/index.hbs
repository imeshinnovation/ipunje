{{>navbar}}
<div class="container">

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicio</a></li>
            <li class="breadcrumb-item active" aria-current="page">Administración</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header">Administración</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 mb-2">
                    <div class="card">
                        <div class="card-body">
                            <button class="btn btn-primary mb-2 w-100 text-start"
                                onclick="$('#mainadmon').load('/admon/members').fadeIn('500');"><i
                                    class="fas fa-users fa-fw ms-4 me-2" ></i>Usuarios</button>
                            <button class="btn btn-primary mb-2 w-100 text-start" onclick="$('#mainadmon').load('/admon/roles').fadeIn('500');"><i
                                    class="fas fa-dice-d6 fa-fw ms-4 me-2"></i>Roles</button>
                            <button class="btn btn-primary mb-2 w-100 text-start" onclick="$('#mainadmon').load('/admon/licencias').fadeIn('500');"><i
                                    class="fas fa-user-graduate fa-fw ms-4 me-2"></i>Licencias</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-9 mb-2">
                    <div class="card">
                        <div class="card-body" id="mainadmon"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>


<script>
    $(document).ready(function () {
        $("#mainadmon").load('/admon/members').fadeIn('500');
    });


    $(function () {
        $('[data-toggle="tooltip"]').tooltip()
    })
    function butDispose() {
        $('[data-toggle="tooltip"]').tooltip('hide')
    }

</script>